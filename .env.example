# Contact form — SMTP settings
# Copy this file to .env.local and fill in your values
# Never commit .env.local

SMTP_HOST=mail.lessonscriptor.com
SMTP_PORT=587
SMTP_USER=contact@lessonscriptor.com
SMTP_PASS=your_email_password_here
CONTACT_EMAIL=contact@lessonscriptor.com

# Google Search Console verification token
# Get it from: Search Console > Settings > Ownership verification > HTML tag
# Replace the value in app/[locale]/layout.tsx too
NEXT_PUBLIC_GSC_TOKEN=your_gsc_verification_token_here
